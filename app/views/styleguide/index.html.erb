          </button>
          <button class="btn-lift w-9 h-9 bg-white border border-slate-200 rounded-lg flex items-center justify-center text-slate-400 hover:text-brand-500 hover:border-brand-200">
            <i class="fa-solid fa-bookmark text-sm"></i>
          </button>
          <button class="btn-lift w-9 h-9 bg-white border border-slate-200 rounded-lg flex items-center justify-center text-slate-400 hover:text-brand-500 hover:border-brand-200">
            <i class="fa-solid fa-share-nodes text-sm"></i>
          </button>
          <button class="btn-press w-9 h-9 bg-brand-500 rounded-lg flex items-center justify-center text-white hover:bg-brand-600 transition-colors">
            <i class="fa-solid fa-plus text-sm"></i>
          </button>
          <button class="btn-press w-9 h-9 bg-xp-green rounded-lg flex items-center justify-center text-white">
            <i class="fa-solid fa-play text-xs"></i>
          </button>
          <button class="btn-lift w-9 h-9 bg-white border border-slate-200 rounded-lg flex items-center justify-center text-slate-400 hover:text-red-400 hover:border-red-200">
            <i class="fa-regular fa-trash-can text-sm"></i>
          </button>
        </div>
      </div>

      <div>
        <span class="text-[9px] font-medium tracking-widest uppercase text-slate-300 block mb-4">Contextual</span>
        <div class="flex flex-wrap gap-3 items-center">
          <button class="btn-gradient group px-5 py-2.5 bg-gradient-to-r from-brand-500 to-brand-600 text-white text-sm font-light rounded-lg inline-flex items-center gap-2">
            Add to Collection
            <i class="fa-solid fa-arrow-right text-[10px] opacity-60 group-hover:translate-x-0.5 transition-transform"></i>
          </button>
          <button class="btn-lift px-5 py-2.5 bg-white text-xp-green text-sm font-light rounded-lg border border-xp-green/20 hover:bg-xp-green-light/30 inline-flex items-center gap-2">
            <i class="fa-solid fa-rotate text-[10px]"></i>
            Review Now
          </button>
          <button class="btn-lift group px-5 py-2.5 bg-gradient-to-r from-reward-50 to-white text-reward-500 text-sm font-light rounded-lg border border-reward-200/50 hover:border-reward-300/60 inline-flex items-center gap-2">
            <i class="fa-solid fa-bolt text-[10px]"></i>
            Claim Reward
          </button>
        </div>
      </div>

    </div>
  </section>

  <!-- ==================== FORM ELEMENTS ==================== -->
  <section class="max-w-6xl mx-auto px-6 mb-16">
    <h2 class="text-xl font-extralight text-slate-900 tracking-tight mb-6">Form Elements</h2>
    <div class="bg-white rounded-xl border border-slate-100 p-8 max-w-md space-y-5">
      <div>
        <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Word</label>
        <input type="text" value="木漏れ日" class="w-full px-3.5 py-2 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all" />
      </div>
      <div>
        <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Translation</label>
        <input type="text" placeholder="Enter translation..." class="w-full px-3.5 py-2 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all placeholder:text-slate-300" />
      </div>
      <div>
        <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Language</label>
        <select class="w-full px-3.5 py-2 text-sm font-light text-slate-600 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all appearance-none cursor-pointer">
          <option>Japanese</option>
          <option>Spanish</option>
          <option>Korean</option>
          <option>German</option>
        </select>
      </div>
      <div>
        <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Notes</label>
        <textarea rows="3" placeholder="Add context or example sentences..." class="w-full px-3.5 py-2 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all placeholder:text-slate-300 resize-none"></textarea>
      </div>
      <button class="btn-gradient w-full px-5 py-2.5 bg-gradient-to-r from-brand-500 to-brand-600 text-white text-sm font-light rounded-lg inline-flex items-center justify-center gap-2">
        <i class="fa-solid fa-plus text-[10px] opacity-70"></i>
        Add to Collection
      </button>
    </div>
  </section>

  <!-- ==================== FOOTER ==================== -->
  <footer class="border-t border-slate-100 py-8">
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 rounded bg-brand-500 flex items-center justify-center text-white">
          <%= render "shared/dragon_icon", size: "sm" %>
        </div>
        <span class="text-sm font-extralight text-slate-400">WordHoard</span>
      </div>
      <p class="text-[11px] font-light text-slate-300">Every word you learn is a word you keep.</p>
    </div>
  </footer>

</div>
