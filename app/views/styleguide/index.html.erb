<div class="min-h-screen bg-white font-body">

  <!-- ==================== HEADER / NAV ==================== -->
  <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-lg border-b border-slate-100">
    <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 rounded-lg bg-brand-500 flex items-center justify-center text-white">
          <%= render "shared/dragon_icon", size: "md" %>
        </div>
        <span class="text-lg font-extralight tracking-tight text-slate-900">WordHoard</span>
      </div>
      <nav class="hidden sm:flex items-center gap-8">
        <a href="#" class="text-[13px] font-light text-slate-400 hover:text-slate-900 transition-colors">Dashboard</a>
        <a href="#" class="text-[13px] font-light text-slate-900 transition-colors">Collection</a>
        <a href="#" class="text-[13px] font-light text-slate-400 hover:text-slate-900 transition-colors">Practice</a>
        <a href="#" class="text-[13px] font-light text-slate-400 hover:text-slate-900 transition-colors">Progress</a>
      </nav>
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-reward-50 border border-reward-200">
          <svg class="w-3.5 h-3.5 text-reward-500" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1.323l3.954 1.582 1.599-.8a1 1 0 01.894 1.79l-1.233.616 1.738 5.42a1 1 0 01-.285 1.05A3.989 3.989 0 0115 15a3.989 3.989 0 01-2.667-1.019 1 1 0 01-.285-1.05l1.715-5.349L11 6.477V16h2a1 1 0 110 2H7a1 1 0 110-2h2V6.477L6.237 7.582l1.715 5.349a1 1 0 01-.285 1.05A3.989 3.989 0 015 15a3.989 3.989 0 01-2.667-1.019 1 1 0 01-.285-1.05l1.738-5.42-1.233-.617a1 1 0 01.894-1.789l1.599.799L9 4.323V3a1 1 0 011-1z"/></svg>
          <span class="text-xs font-medium text-reward-600">2,450 XP</span>
        </div>
        <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center">
          <span class="text-xs font-medium text-slate-500">EL</span>
        </div>
      </div>
    </div>
  </header>

  <!-- ==================== HERO ==================== -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-50 via-white to-reward-50/30"></div>
    <div class="relative max-w-6xl mx-auto px-6 py-20 sm:py-28">
      <p class="text-[11px] font-medium tracking-[0.2em] uppercase text-brand-400 mb-4">Your Word Collection</p>
      <h1 class="text-5xl sm:text-6xl font-extralight tracking-tight text-slate-900 leading-[1.1] max-w-2xl">
        Collect words.<br/>
        <span class="text-brand-500">Own languages.</span>
      </h1>
      <p class="mt-6 text-lg font-extralight text-slate-400 max-w-md leading-relaxed">
        Every word you learn is a word you keep. Build your collection, track your mastery, level up.
      </p>
      <div class="mt-8 flex gap-3">
        <button class="btn-gradient px-6 py-2.5 bg-gradient-to-r from-brand-500 to-brand-600 text-white text-sm font-light rounded-lg">
          <i class="fa-solid fa-plus mr-2 text-xs"></i>Start Collecting
        </button>
        <button class="btn-lift px-5 py-2.5 bg-white text-slate-600 text-sm font-light rounded-lg border border-slate-200 hover:border-slate-300 hover:text-slate-900">
          <i class="fa-regular fa-compass mr-2 text-xs"></i>Browse Words
        </button>
      </div>
    </div>
  </section>

  <!-- ==================== STATS DASHBOARD ==================== -->
  <section class="max-w-6xl mx-auto px-6 -mt-2 mb-12">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <!-- Streak -->
      <div class="group bg-white rounded-xl border border-slate-100 p-5 hover:border-brand-200 transition-all hover:shadow-sm">
        <div class="flex items-center justify-between mb-3">
          <span class="text-[11px] font-medium tracking-wider uppercase text-slate-300">Streak</span>
          <div class="animate-pulse-subtle">
            <svg class="w-5 h-5 text-reward-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"/></svg>
          </div>
        </div>
        <div class="flex items-baseline gap-1">
          <span class="text-3xl font-extralight text-slate-900 animate-count">14</span>
          <span class="text-sm font-light text-slate-300">days</span>
        </div>
      </div>

      <!-- Words Collected -->
      <div class="group bg-white rounded-xl border border-slate-100 p-5 hover:border-brand-200 transition-all hover:shadow-sm">
        <div class="flex items-center justify-between mb-3">
          <span class="text-[11px] font-medium tracking-wider uppercase text-slate-300">Collected</span>
          <svg class="w-5 h-5 text-brand-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>
        </div>
        <div class="flex items-baseline gap-1">
          <span class="text-3xl font-extralight text-slate-900 animate-count">247</span>
          <span class="text-sm font-light text-slate-300">words</span>
        </div>
      </div>

      <!-- Mastered -->
      <div class="group bg-white rounded-xl border border-slate-100 p-5 hover:border-brand-200 transition-all hover:shadow-sm">
        <div class="flex items-center justify-between mb-3">
          <span class="text-[11px] font-medium tracking-wider uppercase text-slate-300">Mastered</span>
          <svg class="w-5 h-5 text-xp-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" /></svg>
        </div>
        <div class="flex items-baseline gap-1">
          <span class="text-3xl font-extralight text-slate-900 animate-count">83</span>
          <span class="text-sm font-light text-slate-300">words</span>
        </div>
      </div>

      <!-- Level -->
      <div class="group bg-white rounded-xl border border-slate-100 p-5 hover:border-reward-200 transition-all hover:shadow-sm">
        <div class="flex items-center justify-between mb-3">
          <span class="text-[11px] font-medium tracking-wider uppercase text-slate-300">Level</span>
          <svg class="w-5 h-5 text-reward-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd" /></svg>
        </div>
        <div class="flex items-baseline gap-1">
          <span class="text-3xl font-extralight text-slate-900 animate-count">12</span>
          <span class="text-sm font-light text-slate-300">collector</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== XP PROGRESS BAR ==================== -->
  <section class="max-w-6xl mx-auto px-6 mb-16">
    <div class="flex items-center justify-between mb-2">
      <div class="flex items-center gap-2">
        <span class="text-xs font-light text-slate-400">Level 12</span>
        <span class="text-[10px] text-slate-300">&rarr;</span>
        <span class="text-xs font-light text-slate-400">Level 13</span>
      </div>
      <span class="text-xs font-mono font-light text-slate-300">2,450 / 3,000 XP</span>
    </div>
    <div class="h-2 bg-slate-50 rounded-full overflow-hidden border border-slate-100">
      <div class="h-full bg-gradient-to-r from-brand-400 to-brand-500 rounded-full animate-fill relative" style="width: 81.6%">
        <div class="absolute inset-0 shimmer rounded-full"></div>
      </div>
    </div>
    <div class="mt-2 flex justify-end">
      <span class="text-[10px] font-light text-slate-300">550 XP to next level</span>
    </div>
  </section>

  <!-- ==================== SECTION: DAILY GOALS (CHECKLIST) ==================== -->
  <section class="max-w-6xl mx-auto px-6 mb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-extralight text-slate-900 tracking-tight">Today's Goals</h2>
      <span class="text-xs font-light text-slate-300">3 of 5 complete</span>
    </div>

    <div class="space-y-2">
      <!-- Completed -->
      <div class="flex items-center gap-4 px-4 py-3 bg-xp-green-light/40 rounded-lg border border-xp-green/10 group">
        <div class="relative">
          <div class="w-6 h-6 rounded-full bg-xp-green flex items-center justify-center check-pop">
            <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <div class="absolute inset-0 w-6 h-6 rounded-full border-2 border-xp-green check-ring"></div>
        </div>
        <span class="text-sm font-light text-slate-400 line-through">Learn 5 new words</span>
        <span class="ml-auto text-[10px] font-mono text-xp-green">+50 XP</span>
      </div>

      <!-- Completed -->
      <div class="flex items-center gap-4 px-4 py-3 bg-xp-green-light/40 rounded-lg border border-xp-green/10">
        <div class="relative">
          <div class="w-6 h-6 rounded-full bg-xp-green flex items-center justify-center check-pop">
            <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
        </div>
        <span class="text-sm font-light text-slate-400 line-through">Review 10 flashcards</span>
        <span class="ml-auto text-[10px] font-mono text-xp-green">+30 XP</span>
      </div>

      <!-- Completed -->
      <div class="flex items-center gap-4 px-4 py-3 bg-xp-green-light/40 rounded-lg border border-xp-green/10">
        <div class="relative">
          <div class="w-6 h-6 rounded-full bg-xp-green flex items-center justify-center check-pop">
            <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
        </div>
        <span class="text-sm font-light text-slate-400 line-through">Practice pronunciation</span>
        <span class="ml-auto text-[10px] font-mono text-xp-green">+20 XP</span>
      </div>

      <!-- Incomplete -->
      <div class="flex items-center gap-4 px-4 py-3 bg-white rounded-lg border border-slate-100 hover:border-brand-200 transition-all cursor-pointer group">
        <div class="w-6 h-6 rounded-full border-2 border-slate-200 group-hover:border-brand-300 transition-colors"></div>
        <span class="text-sm font-light text-slate-600">Complete a quiz</span>
        <span class="ml-auto text-[10px] font-mono text-slate-300">+40 XP</span>
      </div>

      <!-- Incomplete -->
      <div class="flex items-center gap-4 px-4 py-3 bg-white rounded-lg border border-slate-100 hover:border-brand-200 transition-all cursor-pointer group">
        <div class="w-6 h-6 rounded-full border-2 border-slate-200 group-hover:border-brand-300 transition-colors"></div>
        <span class="text-sm font-light text-slate-600">Add a word from reading</span>
        <span class="ml-auto text-[10px] font-mono text-slate-300">+25 XP</span>
      </div>
    </div>
  </section>

  <!-- ==================== FLASHCARDS ==================== -->
  <section class="max-w-6xl mx-auto px-6 mb-16">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-extralight text-slate-900 tracking-tight">Word Collection</h2>
      <div class="flex items-center gap-2">
        <span class="text-[10px] font-medium tracking-wider uppercase text-slate-300">Filter by</span>
        <select class="text-xs font-light text-slate-500 bg-white border border-slate-150 rounded-md px-2 py-1 focus:outline-none focus:ring-1 focus:ring-brand-300 appearance-none cursor-pointer">
          <option>All Languages</option>
          <option>Japanese</option>
          <option>Spanish</option>
          <option>Korean</option>
        </select>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">

      <!-- Common word -->
      <div class="flip-card h-44 cursor-pointer">
        <div class="flip-card-inner relative w-full h-full">
          <div class="flip-card-front absolute inset-0 bg-white rounded-xl border border-slate-100 p-5 flex flex-col justify-between hover:border-slate-200 transition-colors">
            <div class="flex items-center justify-between">
              <span class="text-[9px] font-medium tracking-widest uppercase text-rarity-common/60 px-1.5 py-0.5 rounded bg-slate-50">Common</span>
              <span class="text-[10px] font-light text-slate-300">JP</span>
            </div>
            <div class="text-center">
              <p class="text-2xl font-extralight text-slate-800">食べる</p>
              <p class="text-[10px] font-mono text-slate-300 mt-1">taberu</p>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex gap-0.5">
                <div class="w-1.5 h-1.5 rounded-full bg-xp-green"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-xp-green"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-xp-green"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-slate-200"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-slate-200"></div>
              </div>
              <span class="text-[10px] font-light text-slate-300">Hover to flip</span>
            </div>
          </div>
          <div class="flip-card-back absolute inset-0 bg-brand-500 rounded-xl p-5 flex flex-col justify-between">
            <div class="flex items-center justify-between">
              <span class="text-[9px] font-medium tracking-widest uppercase text-white/50">Definition</span>
              <span class="text-[10px] font-light text-white/40">Verb</span>
            </div>
            <div class="text-center">
              <p class="text-xl font-extralight text-white">to eat</p>
              <p class="text-xs font-extralight text-white/50 mt-2">"I eat sushi every Friday"</p>
            </div>
            <div class="text-center">
              <span class="text-[10px] font-light text-white/40">Collected 3 days ago</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Uncommon word -->
      <div class="flip-card h-44 cursor-pointer">
        <div class="flip-card-inner relative w-full h-full">
          <div class="flip-card-front absolute inset-0 bg-white rounded-xl border border-slate-100 p-5 flex flex-col justify-between hover:border-rarity-uncommon/30 transition-colors">
            <div class="flex items-center justify-between">
              <span class="text-[9px] font-medium tracking-widest uppercase text-rarity-uncommon px-1.5 py-0.5 rounded bg-emerald-50">Uncommon</span>
              <span class="text-[10px] font-light text-slate-300">ES</span>
            </div>
            <div class="text-center">
              <p class="text-2xl font-extralight text-slate-800">madrugada</p>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex gap-0.5">
                <div class="w-1.5 h-1.5 rounded-full bg-xp-green"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-xp-green"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-slate-200"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-slate-200"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-slate-200"></div>
              </div>
              <span class="text-[10px] font-light text-slate-300">Hover to flip</span>
            </div>
          </div>
          <div class="flip-card-back absolute inset-0 bg-rarity-uncommon rounded-xl p-5 flex flex-col justify-between">
            <span class="text-[9px] font-medium tracking-widest uppercase text-white/50">Definition</span>
            <div class="text-center">
              <p class="text-xl font-extralight text-white">early morning / dawn</p>
              <p class="text-xs font-extralight text-white/50 mt-2">"the quiet hours before sunrise"</p>
            </div>
            <span class="text-[10px] font-light text-white/40 text-center">Collected 1 week ago</span>
          </div>
        </div>
      </div>

      <!-- Rare word -->
      <div class="flip-card h-44 cursor-pointer">
        <div class="flip-card-inner relative w-full h-full">
          <div class="flip-card-front absolute inset-0 bg-white rounded-xl border border-slate-100 p-5 flex flex-col justify-between hover:border-brand-200 transition-colors">
            <div class="flex items-center justify-between">
              <span class="text-[9px] font-medium tracking-widest uppercase text-rarity-rare px-1.5 py-0.5 rounded bg-brand-50">Rare</span>
              <span class="text-[10px] font-light text-slate-300">KR</span>
            </div>
            <div class="text-center">
              <p class="text-2xl font-extralight text-slate-800">설레다</p>
              <p class="text-[10px] font-mono text-slate-300 mt-1">seolleda</p>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex gap-0.5">
                <div class="w-1.5 h-1.5 rounded-full bg-xp-green"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-slate-200"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-slate-200"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-slate-200"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-slate-200"></div>
              </div>
              <span class="text-[10px] font-light text-slate-300">Hover to flip</span>
            </div>
          </div>
          <div class="flip-card-back absolute inset-0 bg-rarity-rare rounded-xl p-5 flex flex-col justify-between">
            <span class="text-[9px] font-medium tracking-widest uppercase text-white/50">Definition</span>
            <div class="text-center">
              <p class="text-xl font-extralight text-white">to flutter with excitement</p>
              <p class="text-xs font-extralight text-white/50 mt-2">"a heart full of anticipation"</p>
            </div>
            <span class="text-[10px] font-light text-white/40 text-center">Collected 2 weeks ago</span>
          </div>
        </div>
      </div>

      <!-- Legendary word -->
      <div class="flip-card h-44 cursor-pointer">
        <div class="flip-card-inner relative w-full h-full">
          <div class="flip-card-front absolute inset-0 bg-white rounded-xl border-2 border-reward-200 animate-legendary p-5 flex flex-col justify-between animate-glow">
            <div class="flex items-center justify-between">
              <span class="text-[9px] font-bold tracking-widest uppercase text-rarity-legendary px-1.5 py-0.5 rounded bg-reward-50">Legendary</span>
              <span class="text-[10px] font-light text-slate-300">JP</span>
            </div>
            <div class="text-center">
              <p class="text-2xl font-extralight text-slate-800">木漏れ日</p>
              <p class="text-[10px] font-mono text-slate-300 mt-1">komorebi</p>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex gap-0.5">
                <div class="w-1.5 h-1.5 rounded-full bg-reward-400"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-reward-400"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-reward-400"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-reward-400"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-reward-400"></div>
              </div>
              <span class="text-[10px] font-light text-reward-400">Mastered!</span>
            </div>
          </div>
          <div class="flip-card-back absolute inset-0 bg-gradient-to-br from-reward-500 to-reward-600 rounded-xl p-5 flex flex-col justify-between">
            <span class="text-[9px] font-medium tracking-widest uppercase text-white/50">Definition</span>
            <div class="text-center">
              <p class="text-xl font-extralight text-white">sunlight filtering through leaves</p>
              <p class="text-xs font-extralight text-white/50 mt-2">"untranslatable beauty"</p>
            </div>
            <span class="text-[10px] font-light text-white/40 text-center">A truly rare find</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ==================== COLLECTION PROGRESS ==================== -->
  <section class="max-w-6xl mx-auto px-6 mb-16">
    <h2 class="text-xl font-extralight text-slate-900 tracking-tight mb-6">Collection Progress</h2>
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
      <div class="bg-white rounded-xl border border-slate-100 p-4 text-center">
        <div class="w-10 h-10 rounded-full bg-slate-50 border border-slate-100 mx-auto mb-2 flex items-center justify-center">
          <span class="text-xs font-mono text-rarity-common">142</span>
        </div>
        <p class="text-[10px] font-medium tracking-wider uppercase text-slate-300">Common</p>
