<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-lg border-b border-slate-100">
  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <%= link_to root_path, class: "flex items-center gap-2" do %>
        <div class="w-7 h-7 rounded-lg bg-brand-500 flex items-center justify-center text-white">
          <%= render "shared/dragon_icon", size: "md" %>
        </div>
        <span class="text-lg font-extralight tracking-tight text-slate-900">WordHoard</span>
      <% end %>
    </div>
    <div class="flex items-center gap-6">
      <% if user_signed_in? %>
        <nav class="hidden sm:flex items-center gap-6">
          <%= link_to "Dashboard", root_path, class: "text-[13px] font-light text-slate-400 hover:text-slate-900 transition-colors" %>
          <%= link_to "My Hoard", words_path, class: "text-[13px] font-light #{current_page?(words_path) ? 'text-slate-900' : 'text-slate-400 hover:text-slate-900'} transition-colors" %>
          <%= link_to "Practice", practice_index_path, class: "text-[13px] font-light #{current_page?(practice_index_path) ? 'text-slate-900' : 'text-slate-400 hover:text-slate-900'} transition-colors" %>
        </nav>
        <div class="relative" data-controller="dropdown">
          <button data-action="click->dropdown#toggle" class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center cursor-pointer hover:ring-2 hover:ring-brand-200 transition-all">
            <span class="text-xs font-medium text-slate-500"><%= current_user.first_name&.first&.upcase %><%= current_user.last_name&.first&.upcase %></span>
          </button>
          <div data-dropdown-target="menu" class="hidden absolute right-0 top-full mt-2 w-44 bg-white rounded-xl border border-slate-100 shadow-lg shadow-slate-100/50 py-1.5 z-50">
            <%= link_to edit_user_registration_path, class: "flex items-center gap-2.5 px-4 py-2 text-[13px] font-light text-slate-500 hover:text-slate-900 hover:bg-slate-50 transition-colors" do %>
              <i class="fa-regular fa-user text-[11px] w-4 text-center"></i>
              My Account
            <% end %>
            <%= link_to languages_path, class: "flex items-center gap-2.5 px-4 py-2 text-[13px] font-light text-slate-500 hover:text-slate-900 hover:bg-slate-50 transition-colors" do %>
              <i class="fa-regular fa-flag text-[11px] w-4 text-center"></i>
              My Languages
            <% end %>
            <div class="border-t border-slate-100 my-1.5"></div>
            <%= button_to destroy_user_session_path, method: :delete, class: "w-full flex items-center gap-2.5 px-4 py-2 text-[13px] font-light text-slate-500 hover:text-red-500 hover:bg-slate-50 transition-colors cursor-pointer" do %>
              <i class="fa-solid fa-arrow-right-from-bracket text-[11px] w-4 text-center"></i>
              Sign Out
            <% end %>
          </div>
        </div>
      <% else %>
        <%= link_to "Log in", new_user_session_path, class: "text-[13px] font-light text-slate-400 hover:text-slate-900 transition-colors" %>
        <%= link_to new_user_registration_path, class: "btn-gradient px-4 py-1.5 bg-gradient-to-r from-brand-500 to-brand-600 text-white text-[13px] font-light rounded-lg" do %>
          Sign up
        <% end %>
      <% end %>
    </div>
  </div>
</header>
