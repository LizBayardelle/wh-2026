<div class="min-h-screen bg-gradient-to-br from-brand-50 via-white to-reward-50/20 flex items-center justify-center px-6 py-12">
  <div class="w-full max-w-sm">

    <!-- Logo -->
    <div class="flex items-center justify-center gap-2 mb-10">
      <%= link_to root_path, class: "flex items-center gap-2" do %>
        <div class="w-8 h-8 rounded-lg bg-brand-500 flex items-center justify-center text-white">
          <%= render "shared/dragon_icon", size: "md" %>
        </div>
        <span class="text-xl font-extralight tracking-tight text-slate-900">WordHoard</span>
      <% end %>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-8">
      <h2 class="text-xl font-extralight tracking-tight text-slate-900 mb-1">New password</h2>
      <p class="text-xs font-light text-slate-400 mb-6">Choose a new password for your account</p>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div class="space-y-4">
          <div>
            <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">New password</label>
            <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "w-full px-3.5 py-2.5 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all", placeholder: "Min. 6 characters" %>
            <% if @minimum_password_length %>
              <p class="text-[10px] font-light text-slate-300 mt-1"><%= @minimum_password_length %> characters minimum</p>
            <% end %>
          </div>

          <div>
            <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Confirm password</label>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-3.5 py-2.5 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all", placeholder: "Confirm your new password" %>
          </div>

          <div class="pt-1">
            <%= f.submit "Change password", class: "btn-gradient w-full px-5 py-2.5 bg-gradient-to-r from-brand-500 to-brand-600 text-white text-sm font-light rounded-lg cursor-pointer" %>
          </div>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
