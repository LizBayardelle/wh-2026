<div class="min-h-screen bg-gradient-to-br from-brand-50 via-white to-reward-50/20 flex items-center justify-center px-6 py-12">
  <div class="w-full max-w-sm">

    <!-- Logo -->
    <div class="flex items-center justify-center gap-2 mb-10">
      <%= link_to root_path, class: "flex items-center gap-2" do %>
        <div class="w-8 h-8 rounded-lg bg-brand-500 flex items-center justify-center text-white">
          <%= render "shared/dragon_icon", size: "md" %>
        </div>
        <span class="text-xl font-extralight tracking-tight text-slate-900">WordHoard</span>
      <% end %>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-8">
      <h2 class="text-xl font-extralight tracking-tight text-slate-900 mb-1">Account settings</h2>
      <p class="text-xs font-light text-slate-400 mb-6">Update your profile</p>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">First name</label>
              <%= f.text_field :first_name, autocomplete: "given-name", class: "w-full px-3.5 py-2.5 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all" %>
            </div>
            <div>
              <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Last name</label>
              <%= f.text_field :last_name, autocomplete: "family-name", class: "w-full px-3.5 py-2.5 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all" %>
            </div>
          </div>

          <div>
            <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Email</label>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-3.5 py-2.5 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all" %>
          </div>

          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <div class="flex items-center gap-2 px-3 py-2 bg-reward-50/50 rounded-lg border border-reward-100/50">
              <i class="fa-solid fa-clock text-[10px] text-reward-400"></i>
              <p class="text-xs font-light text-slate-500">Waiting confirmation for: <span class="text-slate-700"><%= resource.unconfirmed_email %></span></p>
            </div>
          <% end %>

          <div>
            <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">New password</label>
            <%= f.password_field :password, autocomplete: "new-password", class: "w-full px-3.5 py-2.5 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all", placeholder: "Leave blank to keep current" %>
            <% if @minimum_password_length %>
              <p class="text-[10px] font-light text-slate-300 mt-1"><%= @minimum_password_length %> characters minimum</p>
            <% end %>
          </div>

          <div>
            <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Confirm new password</label>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full px-3.5 py-2.5 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all", placeholder: "Confirm new password" %>
          </div>

          <div>
            <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Current password <span class="normal-case tracking-normal font-light text-slate-300">(required to save)</span></label>
            <%= f.password_field :current_password, autocomplete: "current-password", class: "w-full px-3.5 py-2.5 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all", placeholder: "Your current password" %>
          </div>

          <div class="pt-1">
            <%= f.submit "Save changes", class: "btn-gradient w-full px-5 py-2.5 bg-gradient-to-r from-brand-500 to-brand-600 text-white text-sm font-light rounded-lg cursor-pointer" %>
          </div>
        </div>
      <% end %>

      <!-- Danger zone -->
      <div class="mt-8 pt-5 border-t border-slate-100">
        <p class="text-[11px] font-medium tracking-wider uppercase text-red-400/70 mb-3">Danger Zone</p>
        <div class="flex items-center justify-between">
          <p class="text-xs font-light text-slate-400">Permanently delete your account</p>
          <%= button_to "Delete account", registration_path(resource_name), method: :delete, data: { confirm: "Are you sure? This cannot be undone." }, class: "btn-lift px-3 py-1.5 text-xs font-light text-red-400 border border-red-200/50 rounded-lg hover:bg-red-50 hover:border-red-200 transition-all cursor-pointer" %>
        </div>
      </div>
    </div>

    <div class="mt-4 text-center">
      <%= link_to "← Back", :back, class: "text-xs font-light text-slate-400 hover:text-slate-600 transition-colors" %>
    </div>

  </div>
</div>
