<div class="min-h-screen bg-gradient-to-br from-brand-50 via-white to-reward-50/20 flex items-center justify-center px-6 py-12">
  <div class="w-full max-w-sm">

    <!-- Logo -->
    <div class="flex items-center justify-center gap-2 mb-10">
      <%= link_to root_path, class: "flex items-center gap-2" do %>
        <div class="w-8 h-8 rounded-lg bg-brand-500 flex items-center justify-center text-white">
          <%= render "shared/dragon_icon", size: "md" %>
        </div>
        <span class="text-xl font-extralight tracking-tight text-slate-900">WordHoard</span>
      <% end %>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-8">
      <h2 class="text-xl font-extralight tracking-tight text-slate-900 mb-1">Welcome back</h2>
      <p class="text-xs font-light text-slate-400 mb-6">Sign in to your collection</p>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Email</label>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full px-3.5 py-2.5 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all placeholder:text-slate-300", placeholder: "you@example.com" %>
          </div>

          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400">Password</label>
              <% if devise_mapping.recoverable? %>
                <%= link_to "Forgot?", new_password_path(resource_name), class: "text-[10px] font-light text-brand-400 hover:text-brand-500 transition-colors" %>
              <% end %>
            </div>
            <%= f.password_field :password, autocomplete: "current-password", class: "w-full px-3.5 py-2.5 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all", placeholder: "Your password" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me, class: "w-3.5 h-3.5 rounded border-slate-300 text-brand-500 focus:ring-brand-200" %>
              <%= f.label :remember_me, class: "text-xs font-light text-slate-400" %>
            </div>
          <% end %>

          <div class="pt-1">
            <%= f.submit "Sign in", class: "btn-gradient w-full px-5 py-2.5 bg-gradient-to-r from-brand-500 to-brand-600 text-white text-sm font-light rounded-lg cursor-pointer" %>
          </div>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
