<tr class="hover:bg-slate-50/50 transition-colors group">
  <% if local_assigns[:show_flag] %>
    <td class="pl-5 pr-1 py-3.5 text-center text-base w-10">
      <%= flag_emoji(word.language) %>
    </td>
  <% end %>
  <td class="px-5 py-3.5">
    <span class="text-sm font-light text-slate-800"><%= word.term %></span>
    <% if word.romanization.present? %>
      <span class="text-[10px] font-mono text-slate-300 ml-1.5"><%= word.romanization %></span>
    <% end %>
    <% if word.pronunciation.present? %>
      <p class="text-[10px] font-light text-slate-400 mt-0.5"><%= word.pronunciation %></p>
    <% end %>
  </td>
  <td class="px-5 py-3.5">
    <span class="text-sm font-extralight text-slate-500"><%= word.translation %></span>
    <% if word.alternative_translations.present? %>
      <p class="text-[10px] font-light text-slate-300 mt-0.5"><%= word.alternative_translations %></p>
    <% end %>
  </td>
  <td class="px-5 py-3.5 hidden sm:table-cell">
    <% if word.part_of_speech.present? %>
      <span class="text-[10px] font-medium tracking-wider text-slate-400 bg-slate-50 px-1.5 py-0.5 rounded"><%= word.part_of_speech %></span>
    <% end %>
    <% if word.formality.present? %>
      <span class="text-[10px] font-light text-slate-300 ml-1"><%= word.formality %></span>
    <% end %>
  </td>
  <td class="px-5 py-3.5 hidden lg:table-cell">
    <% if word.stashes.any? %>
      <div class="flex flex-wrap gap-1">
        <% word.stashes.each do |stash| %>
          <span class="inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded-full bg-brand-50 text-brand-500 text-[9px] font-light">
            <i class="fa-solid fa-box-archive text-[7px] opacity-50"></i>
            <%= stash.name %>
          </span>
        <% end %>
      </div>
    <% end %>
  </td>
  <td class="px-5 py-3.5 hidden sm:table-cell">
    <span class="text-xs font-mono text-slate-400"><%= word.times_reviewed %></span>
  </td>
  <td class="px-5 py-3.5 hidden sm:table-cell">
    <% if word.times_reviewed > 0 %>
      <% acc = (word.times_correct.to_f / word.times_reviewed * 100).round %>
      <span class="text-xs font-mono <%= acc >= 80 ? 'text-xp-green' : acc >= 50 ? 'text-reward-500' : 'text-red-400' %>"><%= acc %>%</span>
    <% else %>
      <span class="text-xs font-mono text-slate-300">—</span>
    <% end %>
  </td>
  <td class="px-5 py-3.5 text-right">
    <div class="flex items-center justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
      <button data-action="click->word-modal#openEdit"
              data-url="<%= word_path(word) %>"
              data-language-id="<%= word.language_id %>"
              data-term="<%= word.term %>"
              data-romanization="<%= word.romanization %>"
              data-pronunciation="<%= word.pronunciation %>"
              data-translation="<%= word.translation %>"
              data-alternative-translations="<%= word.alternative_translations %>"
              data-part-of-speech="<%= word.part_of_speech %>"
              data-pitch-accent="<%= word.pitch_accent %>"
              data-formality="<%= word.formality %>"
              data-register="<%= word.register %>"
              data-gender="<%= word.gender %>"
              data-plural="<%= word.plural %>"
              data-example-sentence="<%= word.example_sentence %>"
              data-example-translation="<%= word.example_translation %>"
              data-usage-notes="<%= word.usage_notes %>"
              data-notes="<%= word.notes %>"
              data-source="<%= word.source %>"
              data-stashes="<%= word.stashes.select(:id, :name, :color).map { |s| { id: s.id, name: s.name, color: s.color } }.to_json %>"
              class="btn-lift w-7 h-7 rounded-md flex items-center justify-center text-slate-300 hover:text-brand-500 hover:bg-brand-50 transition-all cursor-pointer">
        <i class="fa-solid fa-pen text-[9px]"></i>
      </button>
      <%= button_to word_path(word, return_to_language: @active_language_id), method: :delete, data: { confirm: "Delete \"#{word.term}\"?" }, class: "btn-lift w-7 h-7 rounded-md flex items-center justify-center text-slate-300 hover:text-red-400 hover:bg-red-50 transition-all cursor-pointer" do %>
        <i class="fa-regular fa-trash-can text-[9px]"></i>
      <% end %>
    </div>
  </td>
</tr>
