<div class="min-h-screen bg-white font-body">

  <!-- Nav -->
  <%= render "shared/nav" %>

  <div class="max-w-2xl mx-auto px-6 py-12">

    <!-- Header -->
    <div class="mb-10">
      <p class="text-[11px] font-medium tracking-[0.2em] uppercase text-brand-400 mb-2">Your Collection</p>
      <h1 class="text-3xl font-extralight tracking-tight text-slate-900">Languages</h1>
      <p class="text-sm font-extralight text-slate-400 mt-2">Manage the languages you're learning.</p>
    </div>

    <!-- Current languages -->
    <% if @languages.any? %>
      <div class="mb-10">
        <h2 class="text-[11px] font-medium tracking-wider uppercase text-slate-300 mb-3">Your Languages</h2>
        <div class="space-y-2" data-controller="sortable" data-sortable-url-value="<%= sort_languages_path %>">
          <% @languages.each do |language| %>
            <div class="flex items-center gap-4 px-5 py-4 bg-white rounded-xl border border-slate-100 hover:border-brand-200 transition-all group"
                 draggable="true"
                 data-sortable-target="item"
                 data-language-id="<%= language.id %>"
                 data-action="dragstart->sortable#dragstart dragover->sortable#dragover dragend->sortable#dragend">
              <!-- Drag handle -->
              <div class="cursor-grab active:cursor-grabbing text-slate-200 hover:text-slate-400 transition-colors">
                <i class="fa-solid fa-grip-vertical text-[11px]"></i>
              </div>

              <!-- Language info -->
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-light text-slate-800"><%= language.name %></span>
                  <% if language.native_name.present? %>
                    <span class="text-xs font-extralight text-slate-300"><%= language.native_name %></span>
                  <% end %>
                  <% if language.code.present? %>
                    <span class="text-[10px] font-medium tracking-wider text-slate-400 bg-slate-50 px-1.5 py-0.5 rounded"><%= language.code.upcase %></span>
                  <% end %>
                  <% unless language.active? %>
                    <span class="text-[9px] font-medium tracking-widest uppercase text-slate-300 px-1.5 py-0.5 rounded bg-slate-50">Paused</span>
                  <% end %>
                </div>
              </div>

              <!-- Proficiency -->
              <%= form_with model: language, class: "flex items-center gap-2", data: { controller: "auto-submit" } do |f| %>
                <%= f.select :proficiency,
                  Language::PROFICIENCIES.map { |p| [p.capitalize, p] },
                  {},
                  class: "text-[11px] font-light text-slate-500 bg-white border border-slate-150 rounded-md px-2 py-1 focus:outline-none focus:ring-1 focus:ring-brand-300 appearance-none cursor-pointer",
                  onchange: "this.form.requestSubmit()" %>
                <%= f.submit "Save", class: "hidden" %>
              <% end %>

              <!-- Toggle active -->
              <%= form_with model: language, class: "inline" do |f| %>
                <% if language.active? %>
                  <%= f.hidden_field :active, value: "false" %>
                  <button type="submit" class="btn-lift w-8 h-8 rounded-lg border border-slate-200 flex items-center justify-center text-slate-300 hover:text-reward-400 hover:border-reward-200 transition-all" title="Pause">
                    <i class="fa-solid fa-pause text-[10px]"></i>
                  </button>
                <% else %>
                  <%= f.hidden_field :active, value: "true" %>
                  <button type="submit" class="btn-lift w-8 h-8 rounded-lg border border-slate-200 flex items-center justify-center text-slate-300 hover:text-xp-green hover:border-xp-green/30 transition-all" title="Resume">
                    <i class="fa-solid fa-play text-[10px]"></i>
                  </button>
                <% end %>
              <% end %>

              <!-- Remove -->
              <%= button_to language_path(language), method: :delete, data: { confirm: "Remove #{language.name} from your languages?" }, class: "btn-lift w-8 h-8 rounded-lg border border-slate-200 flex items-center justify-center text-slate-300 hover:text-red-400 hover:border-red-200 transition-all cursor-pointer" do %>
                <i class="fa-regular fa-trash-can text-[10px]"></i>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Add from standard list -->
    <div class="mb-10">
      <h2 class="text-[11px] font-medium tracking-wider uppercase text-slate-300 mb-3">Add a Language</h2>
      <div class="bg-white rounded-xl border border-slate-100 p-5">
        <%= form_with url: languages_path, method: :post, class: "flex flex-col sm:flex-row items-stretch sm:items-end gap-3" do |f| %>
          <div class="flex-1">
            <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Language</label>
            <select name="language[code]" class="w-full px-3.5 py-2.5 text-sm font-light text-slate-600 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all appearance-none cursor-pointer">
              <option value="">Choose a language...</option>
              <% @standard_languages.each do |lang| %>
                <% next if @existing_codes.include?(lang["code"]) %>
                <option value="<%= lang["code"] %>"><%= lang["name"] %> &mdash; <%= lang["native_name"] %></option>
              <% end %>
            </select>
          </div>
          <div class="sm:w-36">
            <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Level</label>
            <select name="language[proficiency]" class="w-full px-3.5 py-2.5 text-sm font-light text-slate-600 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all appearance-none cursor-pointer">
              <% Language::PROFICIENCIES.each do |p| %>
                <option value="<%= p %>"><%= p.capitalize %></option>
              <% end %>
            </select>
          </div>
          <button type="submit" class="btn-gradient px-5 py-2.5 bg-gradient-to-r from-brand-500 to-brand-600 text-white text-sm font-light rounded-lg inline-flex items-center justify-center gap-2">
            <i class="fa-solid fa-plus text-[10px] opacity-70"></i>
            Add
          </button>
        <% end %>
      </div>
    </div>

    <!-- Add custom language -->
    <div>
      <h2 class="text-[11px] font-medium tracking-wider uppercase text-slate-300 mb-3">Not on the list?</h2>
      <div class="bg-white rounded-xl border border-dashed border-slate-200 p-5">
        <%= form_with url: languages_path, method: :post, class: "space-y-4" do |f| %>
          <input type="hidden" name="language[custom]" value="true" />
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div>
              <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Language name</label>
              <input type="text" name="language[name]" placeholder="e.g., Klingon" class="w-full px-3.5 py-2.5 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all placeholder:text-slate-300" />
            </div>
            <div>
              <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Native name <span class="normal-case tracking-normal font-light text-slate-300">(optional)</span></label>
              <input type="text" name="language[native_name]" placeholder="e.g., tlhIngan Hol" class="w-full px-3.5 py-2.5 text-sm font-light text-slate-800 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all placeholder:text-slate-300" />
            </div>
          </div>
          <div class="sm:w-48">
            <label class="text-[11px] font-medium tracking-wider uppercase text-slate-400 block mb-1.5">Level</label>
            <select name="language[proficiency]" class="w-full px-3.5 py-2.5 text-sm font-light text-slate-600 bg-white border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand-200 focus:border-brand-300 transition-all appearance-none cursor-pointer">
              <% Language::PROFICIENCIES.each do |p| %>
                <option value="<%= p %>"><%= p.capitalize %></option>
              <% end %>
            </select>
          </div>
          <button type="submit" class="btn-gradient px-5 py-2.5 bg-gradient-to-r from-brand-500 to-brand-600 text-white text-sm font-light rounded-lg inline-flex items-center gap-2">
            <i class="fa-solid fa-plus text-[10px] opacity-70"></i>
            Create Custom Language
          </button>
        <% end %>
      </div>
    </div>

  </div>

</div>
